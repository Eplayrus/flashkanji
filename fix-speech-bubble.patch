+/*
+ * Speech bubble styling
+ *
+ * The original implementation positioned the speech bubble with a fixed
+ * right offset (134px) and a `min(48vw, 205px)` width. On narrow mobile
+ * screens these fixed values meant the bubble’s left edge could extend
+ * far into the panel, overlapping the large "Flash Kanji" heading.
+ *
+ * To make the layout responsive we use CSS `clamp()` functions for both
+ * the horizontal offset and width. The `clamp()` expression picks a
+ * value between a lower bound (0px or 120px), a preferred relative
+ * viewport width, and an upper bound matching the previous design. This
+ * keeps the bubble anchored near the mascot on wide screens while
+ * automatically reducing its footprint on smaller devices.
+ */
+.speech {
+  position: absolute;
+  /* Responsive horizontal positioning: move closer to the right edge as the viewport narrows */
+  right: clamp(0px, 25vw, 134px);
+  bottom: 118px;
+  /* Responsive width: shrink on small screens so it doesn’t overlap the title */
+  width: clamp(120px, 40vw, 205px);
+  padding: 12px 13px;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background: var(--surface-2);
+  box-shadow: 0 16px 34px var(--shadow);
+  color: var(--text);
+  font-weight: 700;
+}
