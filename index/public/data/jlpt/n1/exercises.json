  "lessonOverlays": [
    {
      "lessonId": "bulk-n1-01",
      "intro": {
        "ru": "Первый N1-урок собирает административную и формальную лексику:氏, 統, 保, 第, 結, 派, 案, 策. Смотри не только на перевод, а на то, кто действует, что оформляется и какой вывод делает текст.",
        "en": "The first N1 lesson gathers administrative and formal vocabulary: 氏, 統, 保, 第, 結, 派, 案, 策. Watch not only meaning, but who acts, what is formalized, and what conclusion the text reaches."
      },
      "grammarFocus": [
        "に至るまで",
        "をもって",
        "に即して",
        "を余儀なくされる",
        "にかかわる"
      ],
      "miniReadingId": "n1-reading-lesson-01",
