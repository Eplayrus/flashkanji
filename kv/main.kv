#:import dp kivy.metrics.dp

<GradientBackground@Widget>:
    canvas.before:
        Color:
            rgba: 0.99, 0.94, 0.85, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.95, 0.78, 0.58, 0.25
        Ellipse:
            pos: self.x - self.width * 0.2, self.y + self.height * 0.65
            size: self.width * 1.4, self.height * 0.7

<ImageButton>:
    fit_mode: "contain"

<MDLabel>:
    font_name: app.jp_font_name if app.jp_font_name else "Roboto"

<FlipCard>:
    canvas.before:
        PushMatrix
        Scale:
            x: root.scale_x
            y: 1
            z: 1
            origin: self.center
    canvas.after:
        PopMatrix

<MainMenuScreen>:
    name: "menu"
    GradientBackground:
    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(12)
        Image:
            source: app.asset_path("logo.png")
            size_hint_y: None
            height: dp(120)
            fit_mode: "contain"
        ImageButton:
            source: app.asset_path("btn_cards.png")
            size_hint_y: None
            height: dp(88)
            on_release: root.go_cards()
        ImageButton:
            source: app.asset_path("btn_exercises.png")
            size_hint_y: None
            height: dp(88)
            on_release: root.go_exercises()
        FloatLayout:
            size_hint_y: None
            height: dp(290)
            Image:
                source: app.asset_path("stats_card.png")
                pos_hint: {"x": 0, "y": 0}
                size_hint: 1, 1
                fit_mode: "fill"
            MDLabel:
                text: root.today_text
                pos_hint: {"x": 0.06, "top": 0.92}
                font_style: "Body1"
            MDLabel:
                text: root.streak_text
                pos_hint: {"x": 0.06, "top": 0.84}
                font_style: "Body1"
            MDLabel:
                text: root.today_done_text
                pos_hint: {"x": 0.06, "top": 0.76}
                font_style: "Body1"
            MDLabel:
                text: root.total_learned_text
                pos_hint: {"x": 0.06, "top": 0.68}
                font_style: "Body1"
            MDLabel:
                text: root.weekly_errors_text
                pos_hint: {"x": 0.06, "top": 0.60}
                font_style: "Body1"
            MDLabel:
                text: root.exercises_text
                pos_hint: {"x": 0.06, "top": 0.52}
                font_style: "Body1"
            MDLabel:
                text: root.due_text
                pos_hint: {"x": 0.06, "top": 0.42}
                font_style: "Caption"
            MDLabel:
                text: root.short_text
                pos_hint: {"x": 0.06, "top": 0.34}
                font_style: "Caption"
            MDLabel:
                text: root.long_text
                pos_hint: {"x": 0.06, "top": 0.26}
                font_style: "Caption"

<CardsScreen>:
    name: "cards"
    GradientBackground:
    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(12)
        BoxLayout:
            size_hint_y: None
            height: dp(36)
            MDLabel:
                text: root.today_text
            MDLabel:
                text: root.streak_text
                halign: "right"
        FlipCard:
            id: flip_card
            size_hint_y: 1
            on_touch_down:
                (root.ids.flip_card.flip(), True) if self.collide_point(*args[1].pos) else False
            FloatLayout:
                Image:
                    source: app.asset_path("card.png")
                    size_hint: .94, .94
                    pos_hint: {"center_x": .5, "center_y": .5}
                    fit_mode: "contain"
                MDLabel:
                    text: root.kanji_text if flip_card.is_front else root.back_text
                    halign: "center"
                    valign: "middle"
                    theme_text_color: "Custom"
                    text_color: 0.1, 0.1, 0.1, 1
                    pos_hint: {"center_x": .5, "center_y": .5}
                    size_hint: .78, .78
                    font_style: "H2" if flip_card.is_front else "Body1"
        BoxLayout:
            size_hint_y: None
            height: dp(88)
            spacing: dp(16)
            ImageButton:
                source: app.asset_path("not_remeber.png")
                on_release: root.handle_answer(False)
            ImageButton:
                source: app.asset_path("remember.png")
                on_release: root.handle_answer(True)
        BoxLayout:
            size_hint_y: None
            height: dp(48)
            MDRaisedButton:
                text: "Назад"
                on_release: root.go_home()

<ExerciseScreen>:
    name: "exercises"
    GradientBackground:
    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(12)
        BoxLayout:
            size_hint_y: None
            height: dp(36)
            MDLabel:
                text: root.today_text
            MDLabel:
                text: root.streak_text
                halign: "right"
        MDLabel:
            text: root.sentence_text
            size_hint_y: None
            height: dp(90)
            halign: "center"
            valign: "middle"
        MDLabel:
            text: root.translation_text
            halign: "center"
            size_hint_y: None
            height: dp(32)
        GridLayout:
            id: choices_box
            cols: 4
            size_hint_y: None
            height: dp(180)
            spacing: dp(8)
        MDLabel:
            text: root.result_text
            halign: "center"
            size_hint_y: None
            height: dp(40)
        BoxLayout:
            size_hint_y: None
            height: dp(48)
            spacing: dp(8)
            MDRaisedButton:
                text: "Проверить"
                on_release: root.check_answer()
            MDRaisedButton:
                text: "Сброс"
                on_release: root.reset_slots()
            MDRaisedButton:
                text: "Дальше"
                on_release: root.next_exercise()
        BoxLayout:
            size_hint_y: None
            height: dp(48)
            MDRaisedButton:
                text: "Назад"
                on_release: root.go_home()
