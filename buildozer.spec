[app]
title = FlashKanji
package.name = flashkanji
package.domain = org.example
source.dir = .
source.include_exts = py,kv,png,jpg,json,ttf
version = 0.1
requirements = python3,kivy,kivymd
orientation = portrait
fullscreen = 0
