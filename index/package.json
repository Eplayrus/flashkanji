{
  "name": "flash-kanji",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 4173",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/router.ts src/services/srs.ts src/services/storage.ts src/services/kanjiTts.ts tests/unit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "generate:wiki": "node tools/generate-kanji-wiki.mjs",
    "validate:srs": "node tools/validate-srs.mjs",
    "validate:readings": "node tools/validate-readings.mjs",
    "validate:n1": "node tools/validate-n1-textbook.mjs",
    "convert:webp": "python tools/convert-images-to-webp.py"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.16.5",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.31.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
